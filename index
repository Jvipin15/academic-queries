      height: 62px;
      border-radius: 50%;
      background: var(--success);
      color: var(--white);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      box-shadow: 0 20px 40px rgba(37, 211, 102, 0.35);
    }

    .mobile-toggle {
      display: none;
      background: var(--primary);
      color: var(--white);
      border: none;
      border-radius: 10px;
      padding: 10px 12px;
      font-size: 18px;
      cursor: pointer;
    }

    .success-message {
      margin-top: 12px;
      color: #166534;
      background: #dcfce7;
      border: 1px solid #bbf7d0;
      padding: 12px 14px;
      border-radius: 12px;
      display: none;
    }

    @media (max-width: 1024px) {
      .hero-grid,
      .contact-section .wrap,
      .grid-2,
      .benefit-grid,
      .step-grid,
      .testimonial-grid,
      .footer-grid {
        grid-template-columns: 1fr;
      }

      .hero h2 {
        font-size: 42px;
      }

      .hero-stats {
        grid-template-columns: 1fr;
      }
